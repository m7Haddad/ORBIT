# ORBIT stack configuration.
# Copy to .env and replace every "change-me" with a real secret:
#   openssl rand -hex 24

# Timezone for all containers (and n8n's GENERIC_TIMEZONE)
TZ=UTC

# Public hostnames. Caddy routes by hostname; *.localhost resolves out of the
# box in browsers. Point these at Tailscale MagicDNS names for tailnet access.
ORBIT_DOMAIN=orbit.localhost
N8N_DOMAIN=n8n.orbit.localhost

# PostgreSQL
POSTGRES_DB=orbit
POSTGRES_USER=orbit
POSTGRES_PASSWORD=change-me

# MQTT. Broker auth uses the Mosquitto dynamic-security plugin. Two bootstrap
# accounts here (created by ./infra/mosquitto/gen-dynsec.sh): the backend
# service account and the dynsec admin the backend uses to provision per-device
# credentials at registration. Devices never share these logins.
MQTT_TOPIC_PREFIX=orbit
MQTT_BACKEND_USER=orbit-backend
MQTT_BACKEND_PASSWORD=change-me
MQTT_DYNSEC_ADMIN_USER=orbit-dynsec-admin
MQTT_DYNSEC_ADMIN_PASSWORD=change-me

# Auth — HS256 signing secret for access + service JWTs (openssl rand -hex 32)
JWT_SECRET=change-me

# Weather (Open-Meteo, no API key) — coordinates of home
WEATHER_LATITUDE=0
WEATHER_LONGITUDE=0
WEATHER_LOCATION_NAME=home

# n8n — encryption key for stored credentials; losing it invalidates them.
N8N_ENCRYPTION_KEY=change-me

# Bootstrap admin account, consumed by the seed script
# (docker compose run --rm backend python -m scripts.seed)
ORBIT_ADMIN_EMAIL=admin@example.com
ORBIT_ADMIN_PASSWORD=change-me
